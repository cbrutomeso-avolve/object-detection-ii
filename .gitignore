# =============================================================================
# Per-machine Claude Code settings
# Regenerated by `node scripts/init-claude.js` from settings.example.json.
# Contains absolute paths and is NOT portable between machines.
# =============================================================================
.claude/settings.local.json

# =============================================================================
# Source PDFs
# The PoC works on PNGs (dataset/images/raw/). PDFs are kept locally for
# re-converting via dataset/pdfs/convert_pdfs_to_png.py if ever needed,
# but they are large binaries and not part of the deliverable.
# To force-add a PDF you DO want tracked: `git add -f path/to/file.pdf`.
# =============================================================================
*.pdf

# =============================================================================
# Python
# =============================================================================
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
build/
dist/

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/

# =============================================================================
